VITE_API_URL=http://localhost:3010
# IMPORTANT: use the EIP-155 chainId (what MetaMask cares about), not Truffle's
# legacy net_version. Ganache returns chainId=1337 but net_version=5777 — the
# backend's GANACHE_CHAIN_ID stays 5777 because that's how Truffle indexes its
# artifact, but the browser always sees 1337.
VITE_CHAIN_ID=1337
VITE_NETWORK_NAME=Ganache Local
# Copy the deployed EmployeeRegistry address from the backend .env.
VITE_CONTRACT_ADDRESS=0xPASTE_YOUR_DEPLOYED_CONTRACT_ADDRESS_HERE
# Optional design-generation key placeholder. Never commit a real value.
VITE_DESIGN_API_KEY=
