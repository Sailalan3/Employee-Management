PORT=3010

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/employeeDapp

# Blockchain
GANACHE_RPC_URL=http://127.0.0.1:7545
# Ganache's Truffle artifact key — keep 5777 unless you have a custom network.
GANACHE_CHAIN_ID=1337
# Paste the private key of the Ganache account you want to use as contract owner.
# NEVER commit a real key.
DEPLOYER_PRIVATE_KEY=0xPASTE_YOUR_GANACHE_ACCOUNT_PRIVATE_KEY_HERE
# Pin the deployed EmployeeRegistry address so the backend doesn't drift between
# `truffle migrate` runs. Copy from `blockchain/build/contracts/EmployeeRegistry.json`.
CONTRACT_ADDRESS=0xPASTE_YOUR_DEPLOYED_CONTRACT_ADDRESS_HERE
CONTRACT_ARTIFACT_PATH=../../blockchain/build/contracts/EmployeeRegistry.json

# Auth
# Use any long random string — `openssl rand -hex 32` is fine.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
NONCE_TTL_SECONDS=300
